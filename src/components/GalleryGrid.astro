---
type Item = {
  src: string;
  alt: string;
  caption?: string;
};

type Props = {
  items: Item[];
};

const { items } = Astro.props;
---

<div class="grid gap-3 md:grid-cols-3">
  {items.map((img) => (
    <figure class="overflow-hidden rounded-2xl border border-white/10 bg-white/5">
      <img class="aspect-[4/3] w-full object-cover" src={img.src} alt={img.alt} loading="lazy" />
      {img.caption ? <figcaption class="px-4 py-3 text-xs text-zinc-400">{img.caption}</figcaption> : null}
    </figure>
  ))}
</div>

