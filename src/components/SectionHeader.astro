---
type Props = {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  right?: string;
};

const { eyebrow, title, subtitle, right } = Astro.props;
---

<header class="space-y-3">
  {eyebrow ? <p class="text-xs text-zinc-400">{eyebrow}</p> : null}
  <div class="flex flex-wrap items-end justify-between gap-3">
    <h1 class="text-balance text-3xl font-semibold tracking-tight md:text-5xl">{title}</h1>
    {right ? <div class="text-xs text-zinc-400">{right}</div> : null}
  </div>
  {subtitle ? <p class="max-w-2xl text-pretty text-zinc-300">{subtitle}</p> : null}
</header>

