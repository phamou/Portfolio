---
type Item = {
  title: string;
  subtitle: string;
  bullets: string[];
  accent?: 'indigo' | 'orange' | 'emerald';
};

type Props = {
  items: Item[];
};

const { items } = Astro.props;

const accentToBg: Record<NonNullable<Item['accent']>, string> = {
  indigo: 'from-indigo-500/15',
  orange: 'from-orange-500/15',
  emerald: 'from-emerald-500/15'
};
---

<div class="space-y-3">
  {items.map((item) => (
    <div
      class={[
        'rounded-2xl border border-white/10 bg-gradient-to-br to-transparent p-5',
        item.accent ? accentToBg[item.accent] : 'from-white/5'
      ].join(' ')}
    >
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <div class="font-medium">{item.title}</div>
        <div class="text-xs text-zinc-400">{item.subtitle}</div>
      </div>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-300">
        {item.bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
  ))}
</div>

