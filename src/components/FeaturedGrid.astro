---
type Item = {
  title: string;
  description: string;
  href: string;
  metaLeft?: string;
  metaRight?: string;
};

type Props = {
  items: Item[];
  columns?: 2 | 3;
};

const { items, columns = 3 } = Astro.props;
const grid = columns === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3';
---

<div class={`grid gap-4 ${grid}`}>
  {items.map((item) => (
    <a class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10" href={item.href}>
      {(item.metaLeft || item.metaRight) && (
        <div class="flex items-center justify-between gap-3 text-xs text-zinc-500">
          <span>{item.metaLeft}</span>
          <span>{item.metaRight}</span>
        </div>
      )}
      <div class="mt-2 text-sm font-medium">{item.title}</div>
      <div class="mt-2 text-sm text-zinc-300">{item.description}</div>
      <div class="mt-4 text-xs text-zinc-400 group-hover:text-zinc-200">Open →</div>
    </a>
  ))}
</div>

