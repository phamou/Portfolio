---
import HomeLayout from '../layouts/HomeLayout.astro';
import { withBase } from '../utils/withBase';
---

<HomeLayout
  title="Anh Vu Pham — Data Scientist"
  description="Anh Vu Pham — Montreal-based Data Scientist. Experimentation, causal inference, and product analytics."
>

  <!-- ============== HERO ============== -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-row">
        <div class="avatar">
          <img src={withBase('/images/anh.jpg')} alt="Portrait of Anh Vu Pham" />
        </div>
        <div class="hero-name">
          <p class="hello"><span class="wave">👋</span> Hi, I'm Anh Vu <span style="color: var(--ink-mute);">(think Vietnamese Andrew).</span></p>
          <h1 class="title">Data Scientist who turns <em>data into strategy.</em></h1>
          <div class="role">
            <span>Montreal</span><span class="sep">·</span>
            <span>Shakepay</span>
          </div>
        </div>
      </div>

      <p class="intro">
        I help teams <strong>spot growth opportunities and validate them through experimentation</strong>.
        Day to day, that means designing and analyzing A/B tests, building predictive models, uncovering
        cross-sell and retention plays that drive revenue, and aligning the company on the metrics that
        actually matter. I work the full stack — <strong>SQL, Python, dashboards, and ML</strong> — to inform
        decisions and ship products that move the needle.
      </p>

      <div class="hero-links">
        <a href={withBase('/resume/AnhVuPham_Resume_2026.pdf')} target="_blank" rel="noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <path d="M14 2v6h6"/>
          </svg>
          Resume
        </a>
        <a href="mailto:anhvupham.ma@gmail.com">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1 0 2 1 2 2v12c0 1-1 2-2 2H4c-1 0-2-1-2-2V6c0-1 1-2 2-2z"/>
            <path d="m22 6-10 7L2 6"/>
          </svg>
          anhvupham.ma@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/anh-vu-pham/" target="_blank" rel="noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v15.5H.22zM8.34 8h4.37v2.12h.06c.61-1.16 2.1-2.38 4.33-2.38 4.63 0 5.48 3.05 5.48 7.01V23.5h-4.56v-6.85c0-1.63-.03-3.73-2.27-3.73-2.28 0-2.63 1.78-2.63 3.62V23.5H8.34z"/>
          </svg>
          LinkedIn
        </a>
        <a href="https://github.com/phamou" target="_blank" rel="noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </header>

  <!-- ============== EXPERIENCE ============== -->
  <section class="block" id="work">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>Where <em>I've worked.</em></h2>
        <span class="section-kicker">Experience</span>
      </div>

      <div class="exp-grid">
        <article class="exp-card reveal">
          <div class="exp-head">
            <div class="exp-company">
              <span class="exp-logo sp" aria-hidden="true">
                <img src={withBase('/images/shakepay.png')} alt="" />
              </span>
              Shakepay
            </div>
            <div class="exp-date">Aug 2025 — Present</div>
          </div>
          <div class="exp-role">Data Scientist <span class="loc">Montreal</span></div>
          <ul class="exp-impact">
            <li>Built the success metrics and segmentation frameworks for new product launches, defining actionable growth drivers.</li>
            <li>Drove <b>$10M+ increase in monetary inflows</b> by modeling the causal impact of operational SLAs on deposit velocity and churn.</li>
            <li>Reduced onboarding drop-off by <b>30%</b> via behavioral funnel analysis, shaping roadmap prioritization of high-friction UX gaps.</li>
            <li>Improved A/B test outcomes at <b>100K+ user scale</b> by redesigning event metadata and instrumentation.</li>
            <li>Generated <b>$4M+ in monthly inflows</b> by closing activation gaps among high-value customers with sales-led re-engagement.</li>
          </ul>
          <div class="exp-tags">
            <span class="tag">Experimentation</span>
            <span class="tag">Causal inference</span>
            <span class="tag">Segmentation</span>
            <span class="tag">Instrumentation</span>
          </div>
        </article>

        <article class="exp-card reveal">
          <div class="exp-head">
            <div class="exp-company">
              <span class="exp-logo ad" aria-hidden="true">
                <img src={withBase('/images/autodesk.png')} alt="" />
              </span>
              Autodesk
            </div>
            <div class="exp-date">Nov 2022 — Aug 2025</div>
          </div>
          <div class="exp-role">Data Analyst · Product-led Growth &amp; Lifecycle Marketing <span class="loc">Montreal</span></div>
          <ul class="exp-impact">
            <li>Raised customer renewal rate by <b>13%</b> by developing an onboarding framework for new users using ML on usage data.</li>
            <li>Identified <b>2× revenue growth opportunities</b> based on account attributes and touchpoints across Autodesk's product portfolio.</li>
            <li>Influenced re-engagement strategies by identifying user inactivity thresholds correlating with <b>11% higher churn</b>.</li>
            <li>Designed a reporting framework and data telemetry for user health with cross-functional teams to enable A/B testing.</li>
          </ul>
          <div class="exp-tags">
            <span class="tag">Lifecycle</span>
            <span class="tag">ML</span>
            <span class="tag">Telemetry</span>
            <span class="tag">A/B testing</span>
          </div>
        </article>
      </div>

      <div class="toolbox reveal">
        <span class="toolbox-label">Toolbox</span>
        <span class="tool">SQL</span>
        <span class="tool">Python</span>
        <span class="tool">Snowflake</span>
        <span class="tool">dbt</span>
        <span class="tool">Statsig</span>
        <span class="tool">PostHog</span>
        <span class="tool">Amplitude</span>
        <span class="tool">Looker</span>
        <span class="tool">Tableau</span>
        <span class="tool">PySpark</span>
      </div>
    </div>
  </section>

  <!-- ============== OFF THE CLOCK ============== -->
  <section class="block" id="life">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>Off <em>the clock.</em></h2>
        <span class="section-kicker">The other stuff</span>
      </div>

      <div class="off-grid">
        <article class="off-card reveal">
          <div class="off-photo">
            <img src={withBase('/images/dragonboat.jpg')} alt="Dragon boat racing" loading="lazy" />
          </div>
          <h3 class="off-title">Dragon boat</h3>
          <p class="off-body">
            Competing alongside and against some of the best paddlers in the world keeps me honest — there's
            always more to give, and more to learn. More than anything, this sport has taught me that you only
            win by lifting the people around you; the boat moves fastest when every paddler feels it.
          </p>
        </article>

        <article class="off-card reveal">
          <div class="off-photo">
            <img src={withBase('/images/drinks.jpg')} alt="Two espresso drinks" loading="lazy" />
          </div>
          <h3 class="off-title">Drinks lab</h3>
          <p class="off-body">
            Coffee, matcha, hōjicha, and the occasional cocktail. What keeps me coming back is how bottomless
            the craft feels — every ratio, every ingredient, every technique opens another door. A quiet
            playground for creativity, with a new drink to share with others at the end of it.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============== CONTACT ============== -->
  <section class="contact" id="contact">
    <div class="wrap">
      <div class="reveal">
        <h2>Let's <em>talk.</em></h2>
        <p>
          Recruiting for a data science or analytics role? Working on something curious?
          I'm easy to reach and I like a good conversation.
        </p>
        <div class="contact-links">
          <a class="c-link primary" href="mailto:anhvupham.ma@gmail.com">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1 0 2 1 2 2v12c0 1-1 2-2 2H4c-1 0-2-1-2-2V6c0-1 1-2 2-2z"/>
              <path d="m22 6-10 7L2 6"/>
            </svg>
            Send me an email
          </a>
          <a class="c-link" href="https://www.linkedin.com/in/anh-vu-pham/" target="_blank" rel="noreferrer">LinkedIn</a>
          <a class="c-link" href="https://github.com/phamou" target="_blank" rel="noreferrer">GitHub</a>
          <a class="c-link" href={withBase('/resume/AnhVuPham_Resume_2026.pdf')} target="_blank" rel="noreferrer">Resume ↗</a>
        </div>
      </div>
    </div>
  </section>

</HomeLayout>
