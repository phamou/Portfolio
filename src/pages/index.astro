---
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import { withBase } from '../utils/withBase';
---

<SiteLayout
  title="Home"
  description="Anh Vu Pham — Data Scientist. Dragon boat athlete. Coffee/tea & cocktail experimenter."
>
  <section class="space-y-10">
    <div class="grid gap-8 md:grid-cols-12 md:items-end">
      <div class="space-y-5 md:col-span-8">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-zinc-200">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Building with experimentation, causality, and taste for iteration
        </div>
        <h1 class="text-balance text-4xl font-semibold tracking-tight md:text-6xl">
          Data Scientist with a team-first edge.
        </h1>
        <p class="max-w-2xl text-pretty text-base leading-relaxed text-zinc-300 md:text-lg">
          I build metrics, experimentation, and segmentation frameworks for product growth.
          Outside of work, I race dragon boat to push my physical limits and uplift the people around me.
          I also run a small kitchen lab for coffee, matcha/hōjicha, tea, and cocktails.
        </p>
        <div class="flex flex-wrap gap-3">
          <Button href={withBase('/resume')} variant="primary">Resume</Button>
          <Button href={withBase('/work')} variant="secondary">Work highlights</Button>
          <Button href="mailto:anhvupham.ma@gmail.com" variant="ghost">Email</Button>
        </div>
      </div>

      <div class="grid gap-3 md:col-span-4">
        <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-indigo-500/15 to-transparent p-5">
          <div class="text-xs text-zinc-400">Work</div>
          <div class="mt-1 text-sm font-medium">Experimentation • Causal inference • Product analytics</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-orange-500/15 to-transparent p-5">
          <div class="text-xs text-zinc-400">Athlete</div>
          <div class="mt-1 text-sm font-medium">Compete hard • Train harder • Win together</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-emerald-500/15 to-transparent p-5">
          <div class="text-xs text-zinc-400">Kitchen</div>
          <div class="mt-1 text-sm font-medium">Coffee/tea ritual • Matcha/hōjicha • Cocktail balance</div>
        </div>
      </div>
    </div>

    <section class="grid gap-4 md:grid-cols-3">
      <a href={withBase('/work')} class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10">
        <div class="text-sm font-medium">Work</div>
        <div class="mt-2 text-sm text-zinc-300">
          Impact highlights from Shakepay and Autodesk, plus how I work across instrumentation and experiments.
        </div>
        <div class="mt-4 text-xs text-zinc-400 group-hover:text-zinc-200">Explore work →</div>
      </a>
      <a href={withBase('/athlete')} class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10">
        <div class="text-sm font-medium">Dragon boat</div>
        <div class="mt-2 text-sm text-zinc-300">
          Competitiveness with a team-first mindset: pushing my limits while uplifting the crew.
        </div>
        <div class="mt-4 text-xs text-zinc-400 group-hover:text-zinc-200">Explore athlete →</div>
      </a>
      <a href={withBase('/kitchen')} class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10">
        <div class="text-sm font-medium">Kitchen lab</div>
        <div class="mt-2 text-sm text-zinc-300">
          Coffee, matcha/hōjicha, tea, and cocktails—story-forward experiments with a little rigor underneath.
        </div>
        <div class="mt-4 text-xs text-zinc-400 group-hover:text-zinc-200">Explore kitchen →</div>
      </a>
    </section>
  </section>
</SiteLayout>
