---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = (await getCollection('athlete')).filter((e) => !e.data.draft);
  return entries.map((entry) => {
    const slug = (entry.slug ?? entry.id).replace(/\.(md|mdx)$/, '');
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout title={entry.data.title} description={entry.data.takeaway}>
  <article class="space-y-6">
    <header class="space-y-3">
      <p class="text-xs text-zinc-400">
        <a class="hover:text-white" href="/athlete">Athlete</a>
        <span class="px-2 text-zinc-600">/</span>
        {entry.data.type}
      </p>
      <h1 class="text-balance text-3xl font-semibold tracking-tight md:text-5xl">{entry.data.title}</h1>
      <div class="flex flex-wrap items-center gap-2 text-xs text-zinc-400">
        <span>
          {entry.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long' })}
        </span>
        <span class="text-zinc-600">•</span>
        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-zinc-200">
          {entry.data.type}
        </span>
      </div>
      <p class="max-w-2xl text-pretty text-zinc-200">{entry.data.takeaway}</p>
      {entry.data.highlights?.length ? (
        <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-zinc-300">
          {entry.data.highlights.map((x) => (
            <li>{x}</li>
          ))}
        </ul>
      ) : null}
    </header>

    <div class="prose prose-invert max-w-none prose-p:text-zinc-200 prose-li:text-zinc-200">
      <Content />
    </div>
  </article>
</SiteLayout>

