---
import SiteLayout from '../layouts/SiteLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
---

<SiteLayout title="Resume" description="Resume and links.">
  <section class="space-y-8">
    <SectionHeader
      eyebrow="Resume"
      title="Resume"
      subtitle="If you’re in a hurry, download the PDF. If you have time, browse the work highlights too."
    />

    <div class="flex flex-wrap gap-3">
      <Button href="/resume/AnhVuPham_Resume_2026.pdf" variant="primary" target="_blank" rel="noreferrer">
        Open PDF
      </Button>
      <Button href="/resume/AnhVuPham_Resume_2026.pdf" variant="secondary" download>
        Download
      </Button>
      <Button href="/work" variant="ghost">Work highlights</Button>
    </div>

    <Card class="text-sm text-zinc-300">
      <div class="font-medium text-zinc-100">Quick links</div>
      <div class="mt-3 flex flex-wrap gap-4">
        <a class="hover:text-white" href="mailto:anhvupham.ma@gmail.com">Email</a>
        <a class="hover:text-white" href="https://www.linkedin.com/in/anh-vu-pham/" target="_blank" rel="noreferrer">
          LinkedIn
        </a>
        <a class="hover:text-white" href="https://github.com/phamou" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </div>
    </Card>
  </section>
</SiteLayout>

