---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';

const athleteEntries = (await getCollection('athlete'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const toSlug = (entry: (typeof athleteEntries)[number]) => (entry.slug ?? entry.id).replace(/\.(md|mdx)$/, '');
---

<SiteLayout
  title="Athlete"
  description="Dragon boat: compete hard, push my limits, and make everyone around me better."
>
  <section class="space-y-10">
    <header class="space-y-3">
      <p class="text-xs text-zinc-400">Outside of work · Athlete</p>
      <h1 class="text-balance text-3xl font-semibold tracking-tight md:text-5xl">
        Compete at my limit. Make the boat faster.
      </h1>
      <p class="max-w-2xl text-pretty text-zinc-300">
        I love the edge of racing—training hard, suffering well, and showing up with energy.
        My success in dragon boat only works if everyone around me succeeds too, so I care as much about team lift as I
        do about speed.
      </p>
    </header>

    <section class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-orange-500/15 to-transparent p-5">
        <div class="text-xs text-zinc-400">Theme</div>
        <div class="mt-2 text-sm font-medium">Competitiveness</div>
        <div class="mt-2 text-sm text-zinc-300">I’m here to race, not just participate.</div>
      </div>
      <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-orange-500/15 to-transparent p-5">
        <div class="text-xs text-zinc-400">Theme</div>
        <div class="mt-2 text-sm font-medium">Physical limit</div>
        <div class="mt-2 text-sm text-zinc-300">I train to find the line—and push past it safely.</div>
      </div>
      <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-orange-500/15 to-transparent p-5">
        <div class="text-xs text-zinc-400">Theme</div>
        <div class="mt-2 text-sm font-medium">Uplift the crew</div>
        <div class="mt-2 text-sm text-zinc-300">Boat speed is collective: consistency, feedback, and belief.</div>
      </div>
    </section>

    <section class="grid gap-6 md:grid-cols-12">
      <div class="space-y-4 md:col-span-7">
        <h2 class="text-xl font-semibold tracking-tight">How I train</h2>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
          <div class="text-sm font-medium">Weekly snapshot (example)</div>
          <div class="mt-2 text-sm text-zinc-300">
            A simple structure I like: on-water technique + power sessions, strength training, aerobic base, and recovery.
          </div>
          <ul class="mt-4 grid gap-2 text-sm text-zinc-300 md:grid-cols-2">
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">On-water: technique under fatigue</li>
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">On-water: starts & race pieces</li>
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">Strength: pull + hinge + core</li>
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">Aerobic: steady state</li>
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">Mobility: shoulders & hips</li>
            <li class="rounded-xl border border-white/10 bg-white/5 px-3 py-2">Recovery: sleep + easy movement</li>
          </ul>
        </div>
      </div>

      <div class="space-y-4 md:col-span-5">
        <h2 class="text-xl font-semibold tracking-tight">Team-first competitiveness</h2>
        <div class="grid gap-3">
          {[
            {
              title: 'Consistency is contagious',
              body: 'Show up, train hard, and keep standards high—even when it’s uncomfortable.'
            },
            {
              title: 'Energy and belief',
              body: 'In hard sessions and races, I try to be the person who brings composure and momentum.'
            },
            {
              title: 'Make others better',
              body: 'Feedback, encouragement, and trust—because the boat only moves when we move together.'
            }
          ].map((x) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
              <div class="text-sm font-medium">{x.title}</div>
              <div class="mt-2 text-sm text-zinc-300">{x.body}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="space-y-4">
      <div class="flex flex-wrap items-baseline justify-between gap-3">
        <h2 class="text-xl font-semibold tracking-tight">Entries</h2>
        <div class="text-xs text-zinc-400">{athleteEntries.length} entries</div>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {athleteEntries.map((entry) => (
          <a
            class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:bg-white/10"
            href={`/athlete/${toSlug(entry)}`}
          >
            <div class="flex items-center justify-between gap-3">
              <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-zinc-200">
                {entry.data.type}
              </span>
              <span class="text-xs text-zinc-500">
                {entry.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'short' })}
              </span>
            </div>
            <h3 class="mt-4 text-lg font-semibold tracking-tight">{entry.data.title}</h3>
            <p class="mt-2 text-sm text-zinc-300">{entry.data.takeaway}</p>
            <div class="mt-4 text-xs text-zinc-400 group-hover:text-zinc-200">Read →</div>
          </a>
        ))}
      </div>
      <p class="text-sm text-zinc-400">
        Next step: add real race results and swap in your photos for a gallery section.
      </p>
    </section>
  </section>
</SiteLayout>

